# ============================
# Polymarket BTC 高频套利机器人 - 环境变量配置
# ============================

# 钱包私钥 (Polygon / MetaMask 导出，不带 0x 前缀也可)
PRIVATE_KEY=your_polygon_wallet_private_key_here

# 资金地址 (你的 Polygon 钱包地址，持有 USDC.e)
FUNDER_ADDRESS=0xYourPolygonWalletAddress

# 签名类型: 0=EOA(MetaMask/硬件钱包), 1=Email/Magic钱包, 2=浏览器代理钱包
SIGNATURE_TYPE=0

# 交易模式: live=真实交易, paper=模拟交易(不下单)
TRADE_MODE=paper

# 策略模式: mean_reversion=均值回归, latency_arb=跨市场延迟套利
STRATEGY=mean_reversion

# 偏差阈值 (隐含概率 vs 真实波动率偏差超过此值才下单, 单位: 小数)
DEVIATION_THRESHOLD=0.02

# 单笔下单金额范围 (USDC)
MIN_SIZE=5
MAX_SIZE=20

# 轮询间隔 (秒)
POLL_INTERVAL=300

# 风控参数
MAX_POSITION_PCT=0.01
MAX_DAILY_LOSS_PCT=0.05

# 代理池 (可选, 逗号分隔, 格式: http://user:pass@ip:port)
PROXY_LIST=

# Flask 仪表盘端口
DASHBOARD_PORT=5050
